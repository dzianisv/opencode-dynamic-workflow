{
	"name": "pi-drawer-pierre-diffs",
	"version": "0.1.0",
	"description": "Pierre-style diff renderer for pi — overrides the edit tool to render side-by-side or stacked, syntax-highlighted diffs with colored gutter bars, background tinting, and hunk separators.",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fredcamaral/drawers.git",
		"directory": "packages/pi/pierre-diffs"
	},
	"keywords": [
		"pi",
		"pi-package",
		"diff",
		"edit",
		"renderer"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"files": [
		"src",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": ">=0.79.0",
		"@earendil-works/pi-tui": ">=0.79.0"
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "0.79.3",
		"@earendil-works/pi-tui": "0.79.3"
	}
}
