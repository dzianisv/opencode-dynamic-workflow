	"description": "Persistent agent personas for pi — activate a persona with the $ prefix; its prompt is injected into the system prompt every turn until deactivated.",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fredcamaral/drawers.git",
		"directory": "packages/pi/personas"
	},
	"keywords": [
		"pi",
		"pi-package",
		"personas",
		"agents",
		"system-prompt"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"files": [
		"src",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": ">=0.79.0",
		"@earendil-works/pi-tui": ">=0.79.0"
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "0.79.3",
		"@earendil-works/pi-tui": "0.79.3"
	}
}
